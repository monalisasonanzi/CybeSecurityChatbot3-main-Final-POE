<Window x:Class="CyberSecurityChatbot3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Assistant"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#ECEFF4">

    <Grid>

        <Border Margin="20"
                CornerRadius="25"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="85"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        Background="#1A365D"
                        CornerRadius="25,25,0,0">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LOGO -->
                        <Border Width="55"
                                Height="55"
                                CornerRadius="30"
                                Background="White"
                                VerticalAlignment="Center">

							<TextBlock Text="🔒"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
							
                        </Border>

                        <!-- BOT INFO -->
                        <StackPanel Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Cybersecurity Assistant"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="🟢 Online | Ready to Help"
                                       FontSize="13"
                                       Foreground="#A7F3D0"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <TabControl Grid.Row="1" Margin="15">

    <!-- CHATBOT TAB -->
    <TabItem Header="Chatbot">

        <Grid>

            <TextBox x:Name="txtChat"
                     Margin="10"
                     FontSize="15"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </Grid>

    </TabItem>

    <!-- TASK ASSISTANT TAB -->
    <TabItem Header="Tasks">

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">

                <TextBox x:Name="txtTask"
                         Width="400"
                         Height="35"/>

                <Button Content="Add Task"
                        Width="120"
                        Margin="10,0,0,0"
                        Click="AddTask_Click"/>

            </StackPanel>

            <ListBox x:Name="lstTasks"
                     Grid.Row="1"/>

        </Grid>

    </TabItem>

    <!-- QUIZ TAB -->
    <TabItem Header="Quiz">

        <StackPanel Margin="20">

            <TextBlock x:Name="lblQuestion"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <RadioButton x:Name="rbA"
                         Content="Option A"
                         Margin="0,5"/>

            <RadioButton x:Name="rbB"
                         Content="Option B"
                         Margin="0,5"/>

            <RadioButton x:Name="rbC"
                         Content="Option C"
                         Margin="0,5"/>

            <RadioButton x:Name="rbD"
                         Content="Option D"
                         Margin="0,5"/>

            <Button Content="Submit Answer"
                    Width="180"
                    Height="40"
                    Margin="0,20,0,0"
                    Click="SubmitQuiz_Click"/>

            <TextBlock x:Name="lblScore"
                       FontSize="16"
                       Margin="0,20,0,0"/>

        </StackPanel>

    </TabItem>

    <!-- ACTIVITY LOG TAB -->
    <TabItem Header="Activity Log">

        <Grid Margin="10">

            <ListBox x:Name="lstLogs"/>

        </Grid>

    </TabItem>

</TabControl>

                <!-- MESSAGE BAR -->
                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        CornerRadius="0,0,25,25">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtMessage"
                                 Height="50"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>

                        <Button
                                Margin="848,0,30,0"
                                Content="Send"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="#2563EB"
                                Click="Button_Click" Grid.ColumnSpan="2"/>
                    </Grid>

                </Border>

            </Grid>

        </Border>

    </Grid>
</Window>